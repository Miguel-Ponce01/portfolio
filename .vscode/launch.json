{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch index.html directly (Recommended)",
            "file": "${workspaceFolder}/index.html"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost (Requires Server)",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}